# URL công khai khi deploy (SEO, sitemap)
NEXT_PUBLIC_SITE_URL=https://md.codelab.pro.vn

# Gemini API — lấy key miễn phí tại https://aistudio.google.com/apikey
# Nhiều key cách nhau dấu phẩy
GEMINI_API_KEY=

# Model — 1 tên hoặc nhiều model cách nhau dấu phẩy
# Random theo trọng số 6:2:2 → 2.5-flash-lite 60%, 2.5-flash & 3.1-flash-lite mỗi cái 20%
GEMINI_MODEL=gemini-2.5-flash-lite,gemini-2.5-flash,gemini-3.1-flash-lite

# Provider AI (mặc định: gemini)
AI_PROVIDER=gemini

# Neon PostgreSQL — lưu key Gemini đã xác minh từ người dùng
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
